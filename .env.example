# Servidor
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/controle_processos_pm

# JWT
JWT_SECRET=seu_segredo_jwt_muito_seguro_aqui
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=seu_google_client_id.apps.googleusercontent.com

# CORS - origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Domínio de e-mail autorizado para login (opcional - restringe login a um domínio específico)
# Deixe vazio para permitir qualquer conta Google
GOOGLE_ALLOWED_DOMAIN=pm.ro.gov.br
